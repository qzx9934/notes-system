venv/
__pycache__/
.pytest_cache/
*.pyc
*.tmp
~$*
# 数据库（含用户数据，不上传）
backend/notes.db
# SQLite WAL 模式的临时文件
backend/notes.db-wal
backend/notes.db-shm
# 密钥文件
*.secret_key
# 用户上传的图片（与数据库一样属于运行数据，不入库）
backend/uploads/
# 部署配置（服务器相关，仅忽略仓库根目录的 deploy/，不影响 docs/deploy/ 文档）
/deploy/
# Python 嵌入式环境（不入库）
python/
# 数据库备份文件
backend/notes.db.bak*

# 生成的报告（按需本地生成，不入库）
*.docx
!电厂运行人员工作笔记模板.xlsx
